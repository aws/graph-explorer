---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<article class="card sl-flex not-content">
  <p class="title sl-flex">
    <span class="icon-wrapper">
      <slot name="icon" />
    </span>
    <span set:html={title} />
  </p>
  <div class="body"><slot /></div>
</article>

<style>
  @layer starlight.components {
    .card {
      --sl-card-border: var(--sl-color-accent);
      --sl-card-bg: var(--sl-color-accent-low);
      border: 1px solid var(--sl-color-gray-5);
      background-color: var(--sl-color-black);
      padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
      flex-direction: column;
      gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
    }
    .title {
      font-weight: 600;
      font-size: var(--sl-text-h4);
      color: var(--sl-color-white);
      line-height: var(--sl-line-height-headings);
      gap: 1rem;
      align-items: center;
    }
    .icon-wrapper {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--sl-card-border);
    }
    .icon-wrapper :global(svg) {
      width: 1.333em;
      height: 1.333em;
    }
    .card .body {
      margin: 0;
      font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
    }
  }
</style>
